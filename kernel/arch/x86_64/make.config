# x86_64 freestanding kernel flags. Disable x87/MMX and the red zone (unsafe
# with interrupts). SSE/SSE2 stay enabled: Limine enables them on entry
# (CR0.EM=0, CR4.OSFXSR=1) and the kernel printf uses doubles (%f) in xmm.
# -mcmodel=kernel since we link in the higher half (-2GiB). Limine hands us long
# mode already.
KERNEL_ARCH_CFLAGS=-ffreestanding -fno-stack-protector -fno-stack-clash-protection \
-fno-pic -mno-red-zone -mno-80387 -mno-mmx -mcmodel=kernel
KERNEL_ARCH_CPPFLAGS=
KERNEL_ARCH_LDFLAGS=-static -nostdlib -no-pie -z max-page-size=0x1000 -Wl,--build-id=none
KERNEL_ARCH_LIBS=

# Phase 3: add tty.o, gdt.o, mem.o, pfa.o here as each is ported to x86_64/Limine.
KERNEL_ARCH_OBJS=\
$(ARCHDIR)/tty.o \
# $(ARCHDIR)/boot.o \
