# x86_64 libc/libk configuration.
#
# ARCH_*       apply to the freestanding/hosted libc (user-space, unused yet).
# KERNEL_ARCH_* apply to libk.a, which is linked into the higher-half kernel.
# libk must use the same codegen model as the kernel: the red zone is unsafe
# with interrupts and we link at -2GiB. SSE/SSE2 are left enabled because Limine
# enables them on entry (CR0.EM=0, CR4.OSFXSR=1), and the kernel printf uses
# doubles (%f), which pass in xmm registers.
ARCH_CFLAGS=
ARCH_CPPFLAGS=
KERNEL_ARCH_CFLAGS=-mno-red-zone -mno-80387 -mno-mmx -mcmodel=kernel
KERNEL_ARCH_CPPFLAGS=

ARCH_FREEOBJS=\

ARCH_HOSTEDOBJS=\
